{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vibemouse.local/schema/status.schema.json",
  "title": "VibeMouse Status",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "recording",
    "state"
  ],
  "properties": {
    "recording": {
      "type": "boolean"
    },
    "state": {
      "type": "string",
      "enum": ["idle", "recording", "processing"]
    },
    "listener_mode": {
      "type": "string",
      "enum": ["inline", "child", "off"]
    },
    "last_transcript": {
      "type": "string"
    },
    "ipc_socket": {
      "type": "string"
    },
    "ipc_port": {
      "type": "integer",
      "minimum": 1
    },
    "updated_at": {
      "type": "string"
    }
  }
}
